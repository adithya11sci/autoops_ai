        "lint": "eslint src/",
        "test": "vitest"
    },
    "dependencies": {
        "@fastify/cors": "^9.0.1",
        "@fastify/websocket": "^10.0.1",
        "chromadb": "^1.7.3",
        "dotenv": "^16.4.5",
        "fastify": "^4.26.2",
        "groq-sdk": "^0.5.0",
        "ioredis": "^5.10.1",
        "kafkajs": "^2.2.4",
        "pg": "^8.11.3",
        "pino": "^8.19.0",
        "pino-pretty": "^11.0.0",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/ioredis": "^5.0.0",
        "@types/node": "^20.11.5",
        "@types/pg": "^8.11.0",
        "@types/uuid": "^9.0.7",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^10.1.0",
