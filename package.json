    "version": "1.0.0",
    "description": "Autonomous Multi-Agent DevOps AI System for Intelligent Incident Detection and Resolution",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
