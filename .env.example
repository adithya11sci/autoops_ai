# ============================================
# AutoOps AI - Environment Configuration
# ============================================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Groq API (LLM)
GROQ_API_KEY=gsk_your_groq_api_key_here

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=autoops
POSTGRES_USER=autoops
POSTGRES_PASSWORD=autoops_secret

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=autoops-ai
KAFKA_GROUP_ID=autoops-agents

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Agent Configuration
ANOMALY_THRESHOLD=0.7
MAX_RETRIES=3

# Execution Mode (simulate | live)
EXECUTION_MODE=simulate
