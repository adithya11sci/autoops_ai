# ============================================
# AutoOps AI - Environment Configuration
# ============================================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Groq API (LLM)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL_PLANNING=llama3-70b-8192
GROQ_MODEL_FAST=llama3-8b-8192

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=autoops
POSTGRES_USER=autoops
POSTGRES_PASSWORD=autoops_secret

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=autoops-ai
KAFKA_GROUP_ID=autoops-agents

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Agent Configuration
ANOMALY_THRESHOLD=0.7
MAX_RETRIES=3

# Execution Mode (simulate | live)
EXECUTION_MODE=simulate

# === Enterprise Additions ===

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
EMAIL_ALERT_ADDRESS=oncall@yourcompany.com

# Application URL (for approval links)
APP_URL=http://localhost:3000

# Internal API Key (for approval endpoints)
AUTOOPS_API_KEY=your_internal_api_key

# Vector Similarity
VECTOR_SIMILARITY_THRESHOLD=0.82
TRUST_THRESHOLD_SUCCESS_COUNT=3

# Approval Timeouts
APPROVAL_TIMEOUT_MS=600000
APPROVAL_GROUP_WINDOW_MS=300000

